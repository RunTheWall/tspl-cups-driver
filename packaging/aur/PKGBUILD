# Maintainer: Run The Wall <hello@constly.com>
pkgname=tspl-cups-driver
pkgver=1.2.0
pkgrel=1
pkgdesc="Free CUPS driver for TSPL/TSPL2 thermal label printers (by Run The Wall - https://constly.com)"
arch=('x86_64' 'aarch64' 'armv7h')
url="https://github.com/RunTheWall/tspl-cups-driver"
license=('MIT')
depends=('cups')
makedepends=('gcc' 'make')
conflicts=('hzd950-cups-driver')
replaces=('hzd950-cups-driver')
provides=('hzd950-cups-driver')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('625021a762431c1ef7bcc6b85303e3a95e6238e12641483737b04e3b9cb4978f')

build() {
  cd "$pkgname-$pkgver"
  make
}

package() {
  cd "$pkgname-$pkgver"
  local sb; sb="$(cups-config --serverbin)"
  install -Dm0755 src/rastertotspl    "$pkgdir$sb/filter/rastertotspl"
  install -Dm0700 backend/tspl     "$pkgdir$sb/backend/tspl"
  install -Dm0644 ppd/tspl-label.ppd "$pkgdir/usr/share/ppd/tspl/tspl-label.ppd"
  install -Dm0644 LICENSE            "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm0644 README.md          "$pkgdir/usr/share/doc/$pkgname/README.md"
}
