#!/bin/sh
# ============================================================================
#  tspl — CUPS backend for TSPL/TSPL2 thermal label printers on Linux/ARM.
#
#  Drives ANY USB printer that speaks TSPL — reference-tested on the HZD950-PRO,
#  and matches the common rebadges (Munbyn, iDPRT, HPRT, Beeprt, JADENS, Polono,
#  Xprinter, ...). Writes the (already-TSPL) job straight to the printer's usblp
#  character device, located by USB so it survives reboots / re-enumeration and
#  coexists with other USB printers — unlike the libusb "usb" backend, which
#  detaches usblp and causes a first-job-after-boot race.
#
#  Confirm your printer really speaks TSPL (prints nothing):
#     printf '~!T\r\n' | sudo tee /dev/usb/lp0 ; sudo head -c 32 /dev/usb/lp0
#
#  Device URI:
#     tspl://auto            the TSPL label printer (see auto-match below)
#     tspl://<usb-serial>    a specific unit by its USB serial
#     tspl://<vid>:<pid>     a specific USB id, e.g. tspl://20d1:7008
#     tspl:///dev/usb/lp0    a specific device node
#
#  Auto-match: uses the printer whose USB id is a known TSPL id (KNOWN_IDS
#  below). If yours isn't auto-detected, the error lists the USB printers it
#  DID find — pin one with tspl://<vid>:<pid> or tspl:///dev/usb/lpN, and please
#  open an issue with the id so we can add it to auto-detect.
#
#  Maintained FOR FREE by Run The Wall. If it saved you time, try our free
#  Markdown editor:  https://constly.com
#  SPDX-License-Identifier: MIT
# ============================================================================

# Known TSPL-label USB ids, used only to disambiguate when several USB printers
# are attached. NB: 0fe6:811e is a squatted "ICS Advent Parallel Adapter" id —
# a generic USB-parallel printer bridge also seen on unrelated ESC/POS receipt
# printers (Gainscha GP80, Geyi Q583P) — so auto-match can still pick a
# non-TSPL device on that id; pin by serial/node if you have both kinds.
#   09c6:0426  Beeprt/JADENS/Munbyn-ITPP941/Rollo OEM engine
#              (linux-hardware.org reports it as "Beeprt LabelPrinter")
#   20d1:7008  iDPRT SP410/SP420 (HPRT = same Hanin parent; Polono unconfirmed)
#   0fe6:811e  HZD950-PRO / HERO (reference unit) on the shared bridge id
#   2d84:*     Zhuhai Poskey / Xprinter label printers
#              (b806 = Poskey DT-108B per usb.ids; b528 seen on XP-460B)
KNOWN_IDS="09c6:0426 20d1:7008 0fe6:811e 2d84:*"

usb_attr() {   # $1 = usblp minor, $2 = sysfs attr
    sl=$(readlink -f "/sys/dev/char/180:$1" 2>/dev/null) || return
    d="$sl"
    while [ -n "$d" ] && [ "$d" != "/" ]; do
        if [ -f "$d/idVendor" ]; then cat "$d/$2" 2>/dev/null; return; fi
        d=$(dirname "$d")
    done
}
vidpid() { echo "$(usb_attr "$1" idVendor):$(usb_attr "$1" idProduct)"; }
is_known() {   # $1 = "vid:pid"
    for k in $KNOWN_IDS; do case "$1" in $k) return 0 ;; esac; done
    return 1
}
each_node() {  # -> "minor node" per usblp device
    for n in /dev/usb/lp*; do [ -e "$n" ] || continue; echo "${n##*lp} $n"; done
}

# Resolve target node. $1 = auto | serial | vid:pid | /dev/... . Echoes a node.
# Safe by default: "auto" only matches a KNOWN TSPL usb id — it will NOT grab an
# unknown printer (e.g. a laser). Pin unknown units by vid:pid or node.
find_node() {
    want=$1
    case "$want" in /dev/*) [ -e "$want" ] && echo "$want"; return ;; esac
    known=""
    while read -r m n; do
        [ -n "$m" ] || continue
        vp=$(vidpid "$m"); ser=$(usb_attr "$m" serial)
        case "$want" in
            ''|auto) is_known "$vp" && [ -z "$known" ] && known=$n ;;
            *:*)     [ "$vp" = "$want" ] && { echo "$n"; return; } ;;
            *)       [ "$ser" = "$want" ] && { echo "$n"; return; } ;;
        esac
    done <<EOF
$(each_node)
EOF
    case "$want" in ''|auto) [ -n "$known" ] && echo "$known" ;; esac
}

# --- discovery mode (no args) ---
if [ "$#" -eq 0 ]; then
    [ -n "$(find_node auto)" ] && \
      echo 'direct tspl://auto "Unknown" "TSPL label printer (Run The Wall driver)"'
    exit 0
fi

# --- print mode: job user title copies options [file] ---
echo "INFO: tspl — FREE Linux/Pi TSPL label-printer driver by Run The Wall. Support us: https://constly.com" 1>&2

WANT=${DEVICE_URI#tspl://}
WANT=${WANT#tspl:}
[ "$WANT" = "$DEVICE_URI" ] && WANT=auto        # bare / unknown -> auto

DEV=$(find_node "$WANT")
i=0
while [ -z "$DEV" ] && [ -z "$(each_node)" ] && [ "$i" -lt 30 ]; do   # boot settling
    echo "INFO: waiting for a USB printer to appear..." 1>&2
    sleep 2; i=$((i + 1)); DEV=$(find_node "$WANT")
done
if [ -z "$DEV" ]; then
    echo "ERROR: no matching TSPL label printer on USB (wanted: ${WANT:-auto})." 1>&2
    echo "ERROR: USB printers present:" 1>&2
    each_node | while read -r m n; do
        echo "ERROR:   $n  (usb $(vidpid "$m"), serial $(usb_attr "$m" serial))" 1>&2
    done
    echo "ERROR: pick one with device URI tspl://<vid>:<pid> or tspl:///dev/usb/lpN" 1>&2
    exit 1
fi
echo "INFO: using TSPL printer at $DEV (usb $(vidpid "${DEV##*lp}"))" 1>&2

if [ -n "$6" ]; then cat "$6" > "$DEV"; else cat > "$DEV"; fi
exit $?
